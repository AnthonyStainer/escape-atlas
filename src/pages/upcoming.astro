---
import Base from '../layouts/Base.astro';
import { formatDate, upcoming } from '../lib/rooms';
---

<Base title="Upcoming" description="Public-safe upcoming escape-room plans for Anthony and Trenna." eyebrow="Next coordinates">
  <header class="page-header">
    <h1>The doors ahead.</h1>
    <p class="lede">Booked rooms appear here from the Fastmail-authoritative diary after Mei has verified and reduced them to public-safe details.</p>
  </header>

  {upcoming.length ? (
    <div class="room-list">
      {upcoming.map((event) => (
        <article class="room-card">
          <div class="room-card__number" aria-hidden="true">NEXT</div>
          <div class="room-card__body">
            <div class="room-card__meta">
              <time datetime={event.time ? `${event.date}T${event.time}` : event.date}>
                {formatDate(event.date)}{event.time ? ` · ${event.time}` : ''}
              </time>
              <span>{event.location}</span>
            </div>
            <h3>{event.game}</h3>
            <p class="room-card__venue">{event.venue}</p>
            {event.note && <div class="room-card__facts"><span>{event.note}</span></div>}
          </div>
        </article>
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <p class="eyebrow">The map is open</p>
      <h2>No public upcoming room is recorded yet.</h2>
      <p>That does not mean nothing is being planned. It means no verified booking currently belongs on the public atlas.</p>
    </div>
  )}
</Base>
