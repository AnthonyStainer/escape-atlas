---
import Base from '../../layouts/Base.astro';
import {
  formatDate,
  formatDuration,
  roomSlug,
  rooms,
  roomPhotoCaption,
  roomTitle,
  type Room,
} from '../../lib/rooms';

export function getStaticPaths() {
  return rooms.map((room, index) => ({
    params: { slug: roomSlug(room) },
    props: {
      room,
      previous: rooms[index - 1] ?? null,
      next: rooms[index + 1] ?? null,
    },
  }));
}

interface Props {
  room: Room;
  previous: Room | null;
  next: Room | null;
}

const { room, previous, next } = Astro.props;
const title = roomTitle(room);
const photoCaption = roomPhotoCaption(room);
---

<Base title={title} description={`Room #${room.id}: ${title}, ${room.venue ?? 'venue unknown'}, ${room.location}.`} eyebrow="A point on the map">
  <div class="room-detail">
    <article class="room-detail__main">
      <p class="room-number-large">ROOM {String(room.id).padStart(3, '0')}</p>
      <h1>{title}</h1>
      <p class="lede">{room.venue ?? 'Venue unknown'} · {room.location}</p>
      {room.publicNote && <p>{room.publicNote}</p>}
      {room.sourceFlags.includes('duplicate-core-fields') && (
        <p class="quiet">One of two separate games played here on the same day. Their names have been lost to history.</p>
      )}
      {room.photo && (
        <figure class="room-photo">
          <img
            src={room.photo.src}
            alt={room.photo.alt}
            width={room.photo.width}
            height={room.photo.height}
            loading="eager"
            decoding="async"
          />
          {photoCaption && <figcaption>{photoCaption}</figcaption>}
        </figure>
      )}
    </article>

    <aside class="room-detail__aside" aria-label="Room facts">
      <dl class="fact-list">
        <div><dt>Date</dt><dd>{formatDate(room.date)}</dd></div>
        <div><dt>Location</dt><dd>{room.location}</dd></div>
        <div><dt>Venue</dt><dd>{room.venue ?? 'Unknown'}</dd></div>
        <div><dt>Escape time</dt><dd>{formatDuration(room.completionTime)}</dd></div>
        <div><dt>Players</dt><dd>{room.players}</dd></div>
        <div><dt>Game length</dt><dd>{room.allottedMinutes} min</dd></div>
      </dl>
    </aside>
  </div>

  <nav class="pagination-row" aria-label="Adjacent rooms">
    {previous ? <a class="button button--ghost" href={`/room/${roomSlug(previous)}/`}>← Room {previous.id}</a> : <span></span>}
    {next ? <a class="button button--ghost" href={`/room/${roomSlug(next)}/`}>Room {next.id} →</a> : <span></span>}
  </nav>
</Base>
