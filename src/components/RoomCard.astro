---
import type { Room } from '../lib/rooms';
import { formatDate, formatDuration, roomSlug, roomTitle } from '../lib/rooms';

interface Props {
  room: Room;
  compact?: boolean;
}

const { room, compact = false } = Astro.props;
---

<article class:list={['room-card', { compact }]} data-room-card>
  <div class="room-card__number" aria-label={`Room number ${room.id}`}>{String(room.id).padStart(3, '0')}</div>
  <div class="room-card__body">
    <div class="room-card__meta">
      <time datetime={room.date}>{formatDate(room.date)}</time>
      <span>{room.location}</span>
    </div>
    <h3><a href={`/room/${roomSlug(room)}/`}>{roomTitle(room)}</a></h3>
    <p class="room-card__venue">{room.venue ?? 'Venue unknown'}</p>
    {!compact && (
      <div class="room-card__facts">
        <span>{room.completionTime ? `Escaped in ${formatDuration(room.completionTime)}` : 'Finish time unknown'}</span>
        {room.players && <span>{room.players} players</span>}
      </div>
    )}
  </div>
  <a class="room-card__arrow" href={`/room/${roomSlug(room)}/`} aria-label={`Open ${roomTitle(room)}`}>↗</a>
</article>
